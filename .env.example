# Local backend configuration. Copy to .env and fill in.
# Postgres connection string (local or Neon). Required by cmd/api and cmd/migrate.
# `just db` starts a local Postgres that matches this URL.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/shopping_list?sslmode=disable
# Port for `go run ./cmd/api` (default 8080).
PORT=8080

# Local backend configuration. Copy to .env and fill in.
# Postgres connection string (local or Neon). Required by cmd/api and cmd/migrate.
# `just db` starts a local Postgres that matches this URL.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/shopping_list?sslmode=disable
# Port for `go run ./cmd/api` (default 8080).
PORT=8080
# Log level for structured (slog) JSON logging: debug|info|warn|error (default info).
LOG_LEVEL=info
# Per-request deadline as a Go duration (default 5s). Bounds every handler and
# cancels in-flight Postgres queries so one slow request can't starve the pool.
REQUEST_TIMEOUT=5s
# OIDC sign-in (Google). Issuer defaults to https://accounts.google.com.
# OIDC_AUDIENCE is your Google OAuth client id; leave empty to disable auth
# locally (the server still boots; auth-only endpoints return 401).
OIDC_ISSUER=https://accounts.google.com
OIDC_AUDIENCE=
# Comma-separated CORS allow-list for the Flutter web client (browser origins).
# Empty/unset falls back to a local-dev default (http://localhost:* and
# http://127.0.0.1:*), never an unconditional "*". Set this to your real web
# origin(s) in production, e.g. https://handla.example.com,https://www.handla.example.com
CORS_ALLOWED_ORIGINS=
